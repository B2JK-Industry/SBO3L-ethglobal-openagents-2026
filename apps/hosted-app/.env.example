# SBO3L hosted app — required environment variables.
# Copy to .env.local for development; set in Vercel project settings for prod.

# NextAuth — required
AUTH_SECRET=replace_me_run_npx_auth_secret_to_generate
AUTH_URL=http://localhost:3000

# Identity providers — at least one is required for login to work.
# Each provider only activates when both ID + SECRET are set.

# GitHub OAuth — register at https://github.com/settings/developers
# Authorization callback URL: ${AUTH_URL}/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth — Google Cloud Console → APIs & Services → Credentials
# Authorized redirect URI: ${AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Apple Sign In — most operator-heavy provider.
# AUTH_APPLE_ID is your Services ID (com.sbo3l.web etc.).
# AUTH_APPLE_SECRET is a JWT signed with your Apple private key,
# generated either by `npx auth secret apple` or out-of-band per
# https://authjs.dev/getting-started/providers/apple
AUTH_APPLE_ID=
AUTH_APPLE_SECRET=

# Role assignment — comma-separated lowercase identifiers. Anyone not
# in any list defaults to `viewer`. Take effect on next session
# refresh (no re-login required).
ADMIN_GITHUB_LOGINS=
ADMIN_EMAILS=
OPERATOR_GITHUB_LOGINS=
OPERATOR_EMAILS=

# SBO3L daemon endpoint — required for live agent/audit/capsule data.
# Falls back to mock fixtures + a "demo mode" banner when unreachable.
# WebSocket events feed connects at ${SBO3L_DAEMON_URL}/v1/events.
SBO3L_DAEMON_URL=http://localhost:8080
