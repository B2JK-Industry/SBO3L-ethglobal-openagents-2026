# SBO3L hosted app — required environment variables.
# Copy to .env.local for development; set in Vercel project settings for prod.

# NextAuth — required
AUTH_SECRET=replace_me_run_npx_auth_secret_to_generate
AUTH_URL=http://localhost:3000

# GitHub OAuth provider — register at https://github.com/settings/developers
# Authorization callback URL: ${AUTH_URL}/api/auth/callback/github
AUTH_GITHUB_ID=replace_me
AUTH_GITHUB_SECRET=replace_me

# SBO3L daemon endpoint — required for live agent/audit/capsule data.
# Falls back to mock fixtures + a "demo mode" banner when unreachable.
# WebSocket events feed connects at ${SBO3L_DAEMON_URL}/v1/events.
SBO3L_DAEMON_URL=http://localhost:8080
