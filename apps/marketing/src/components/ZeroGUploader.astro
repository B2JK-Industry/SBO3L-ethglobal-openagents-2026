---
// ZeroGUploader — drop a Passport capsule JSON, push it to 0G Storage,
// get back a content-addressed `rootHash` (DG-1).
//
// Two-path flow:
//
//   1. Primary path: probe 0G Galileo testnet liveness (5s timeout).
//      The TS SDK (@0gfoundation/0g-storage-ts-sdk) cannot run fully
//      client-side without exposing a private key in the browser bundle
//      (the indexer.upload() call needs a signer to pay storage fees),
//      so the in-browser "primary path" stops at the liveness probe and
//      hands off to the manual web UI. When SBO3L's server-side relay
//      ships, this same probe gates the auto-upload code path.
//
//   2. Fallback path: open https://storagescan-galileo.0g.ai/tool in a
//      new tab, instruct the user to drop the same file there, copy the
//      rootHash back into this page. We then surface the permalink at
//      https://storagescan-galileo.0g.ai/file/<rootHash> and offer a
//      copy-to-clipboard.
//
// 0G testnet has been historically flaky (faucet down, indexer
// timeouts, KV nodes unreliable — see ETHGlobal Discord) which is the
// whole reason the manual fallback exists at all. Even when the SDK
// path lights up, the fallback button stays visible for users who hit
// indexer 5xx mid-upload.
//
// CSP impact: vercel.json adds `https://indexer-storage-testnet-turbo.0g.ai`
// and `https://evmrpc-testnet.0g.ai` to connect-src so the liveness
// probe doesn't trip Content-Security-Policy on production. The
// storagescan-galileo URL opens in a new tab (window.open) so it
// bypasses the iframe frame-src restriction entirely.
//
// Component is a pure Astro island. The runtime lives at
// `public/zerog-uploader-runtime.js` and is loaded via `<script src=…>`
// rather than `is:inline` — Vercel's CSP is `script-src 'self'
// 'wasm-unsafe-eval'` (no `'unsafe-inline'`), so any inline script is
// blocked in production. Constants the runtime needs (storagescan URLs,
// indexer probe URL, timeout, max file bytes) flow through `data-*`
// attributes on the root element. Multiple instances on a page each get
// their own `id`; the runtime auto-binds every `[data-zerog-uploader]`
// at DOMContentLoaded.

interface Props {
  /// Optional id for the inline component instance, used when mounting
  /// more than one uploader on the same page.
  id?: string;
}

const { id = "zerog-uploader" } = Astro.props;

const STORAGESCAN_TOOL_URL = "https://storagescan-galileo.0g.ai/tool";
const STORAGESCAN_FILE_URL = "https://storagescan-galileo.0g.ai/file";
const INDEXER_PROBE_URL = "https://indexer-storage-testnet-turbo.0g.ai";
const PROBE_TIMEOUT_MS = 5000;
const MAX_FILE_BYTES = 1024 * 1024; // 1 MB — 0G testnet practical cap.
---

<section
  class="zg-uploader"
  id={id}
  data-state="idle"
  data-zerog-uploader
  data-storagescan-tool-url={STORAGESCAN_TOOL_URL}
  data-storagescan-file-url={STORAGESCAN_FILE_URL}
  data-indexer-probe-url={INDEXER_PROBE_URL}
  data-probe-timeout-ms={String(PROBE_TIMEOUT_MS)}
  data-max-file-bytes={String(MAX_FILE_BYTES)}
>
  <header class="zg-head">
    <h2>Upload a Passport capsule to 0G Storage</h2>
    <p class="lede">
      Drop a capsule JSON below. We'll attempt to push it to 0G's
      Galileo testnet and return a content-addressed
      <code>rootHash</code>. If the testnet's flaky (it has been all
      week), we fall back to the manual web tool — same outcome, two
      extra clicks.
    </p>
  </header>

  <div class="zg-drop" tabindex="0" role="button" aria-label="Drop or click to pick a capsule JSON">
    <input type="file" accept="application/json,.json" hidden />
    <div class="zg-drop-prompt">
      <strong>Drag a capsule JSON here</strong>
      <span>or click to pick a file (max 1 MB)</span>
    </div>
    <div class="zg-drop-loaded" hidden>
      <strong class="zg-file-name"></strong>
      <span class="zg-file-meta"></span>
      <button type="button" class="zg-clear">Clear</button>
    </div>
  </div>

  <div class="zg-error" hidden role="alert"></div>

  <div class="zg-actions">
    <button type="button" class="btn primary zg-upload" disabled>
      Push to 0G Storage
    </button>
    <span class="zg-status">idle</span>
  </div>

  <div class="zg-fallback" hidden>
    <h3>0G SDK couldn't auto-push — manual fallback</h3>
    <ol>
      <li>We've opened the <a href={STORAGESCAN_TOOL_URL} target="_blank" rel="noopener noreferrer">0G storage tool</a> in a new tab.</li>
      <li>Drag the same file there and click <strong>Upload</strong>.</li>
      <li>Copy the <code>rootHash</code> the tool shows you.</li>
      <li>Paste it below and we'll surface the permalink + verify it locally.</li>
    </ol>
    <label for={`${id}-manual-hash`} class="zg-lbl">rootHash from 0G storage tool</label>
    <div class="zg-hash-row">
      <input
        type="text"
        id={`${id}-manual-hash`}
        class="zg-manual-hash"
        placeholder="0x…"
        autocomplete="off"
        spellcheck="false"
      />
      <button type="button" class="btn ghost zg-manual-submit">Verify</button>
    </div>
    <p class="zg-hash-help">
      0G Storage is content-addressed — the rootHash <em>is</em> the
      proof of upload. No further verification needed beyond format.
    </p>
  </div>

  <div class="zg-success" hidden>
    <h3>Capsule pinned to 0G Storage</h3>
    <p class="zg-success-source"></p>
    <div class="zg-hash-display">
      <span class="zg-hash-label">rootHash</span>
      <code class="zg-hash-value"></code>
      <button type="button" class="btn ghost zg-copy">Copy</button>
    </div>
    <p>
      Permalink: <a class="zg-permalink" target="_blank" rel="noopener noreferrer"></a>
    </p>
  </div>
</section>

<style>
  .zg-uploader {
    max-width: var(--max);
    margin: 2em auto;
    padding: 1.5em;
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    background: var(--bg);
  }
  .zg-head h2 { font-size: 1.4em; font-weight: 700; margin: 0 0 0.4em; }
  .zg-head .lede { color: var(--muted); margin: 0 0 1.5em; }

  .zg-drop {
    border: 2px dashed var(--border);
    border-radius: var(--r-md);
    padding: 2em 1em;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
  }
  .zg-drop:hover, .zg-drop.zg-drag {
    border-color: var(--accent);
    background: var(--code-bg);
  }
  /* R20 Task B: previous rule killed `outline` on `:focus`, removing
     the keyboard ring entirely (border-color change alone isn't
     reliable for users with reduced color sensitivity). Restored a
     2px accent outline on `:focus-visible` so keyboard tabs ring but
     mouse clicks don't. */
  .zg-drop:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-color: var(--accent);
    background: var(--code-bg);
  }
  .zg-drop strong { display: block; font-size: 1em; margin-bottom: 0.3em; }
  .zg-drop span { color: var(--muted); font-size: 0.9em; }
  .zg-drop-loaded {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.8em;
    flex-wrap: wrap;
  }
  .zg-drop-loaded strong { display: inline; margin: 0; font-family: var(--font-mono); font-size: 0.9em; }
  .zg-clear {
    background: none;
    border: 1px solid var(--border);
    border-radius: var(--r-sm);
    padding: 0.3em 0.7em;
    font-size: 0.8em;
    cursor: pointer;
    color: var(--muted);
  }
  .zg-clear:hover { border-color: var(--accent); color: var(--accent); }

  .zg-error {
    margin-top: 1em;
    padding: 0.7em 1em;
    border-radius: var(--r-sm);
    background: #ffd6d6;
    color: #8b0000;
    font-family: var(--font-mono);
    font-size: 0.85em;
  }

  .zg-actions {
    display: flex;
    align-items: center;
    gap: 1em;
    margin-top: 1.2em;
  }
  .zg-actions .zg-upload {
    border: none;
    cursor: pointer;
    font-size: 0.95em;
  }
  .zg-actions .zg-upload:disabled { opacity: 0.5; cursor: not-allowed; }
  .zg-status {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.85em;
  }

  .zg-fallback, .zg-success {
    margin-top: 1.5em;
    padding: 1.2em;
    border-radius: var(--r-md);
    border: 1px solid var(--border);
    background: var(--code-bg);
  }
  .zg-fallback h3, .zg-success h3 {
    font-size: 1.05em;
    font-weight: 700;
    margin: 0 0 0.7em;
  }
  .zg-fallback ol { margin: 0 0 1em; padding-left: 1.4em; color: var(--muted); }
  .zg-fallback li { margin-bottom: 0.3em; }
  .zg-lbl { display: block; font-weight: 600; font-size: 0.9em; margin-bottom: 0.3em; }
  .zg-hash-row {
    display: flex;
    gap: 0.5em;
    flex-wrap: wrap;
  }
  .zg-hash-row input {
    flex: 1;
    min-width: 280px;
    padding: 0.55em 0.8em;
    border: 1px solid var(--border);
    border-radius: var(--r-sm);
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--bg);
    color: var(--fg);
  }
  .zg-hash-row .btn { cursor: pointer; border: 1px solid var(--border); background: var(--bg); }
  .zg-hash-help { margin: 0.6em 0 0; color: var(--muted); font-size: 0.82em; }

  .zg-success-source { color: var(--muted); font-size: 0.85em; margin: 0 0 0.8em; font-style: italic; }
  .zg-hash-display {
    display: flex;
    gap: 0.6em;
    align-items: center;
    flex-wrap: wrap;
    padding: 0.7em 0.9em;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--r-sm);
    margin-bottom: 0.6em;
  }
  .zg-hash-label {
    font-family: var(--font-mono);
    font-size: 0.8em;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .zg-hash-value {
    flex: 1;
    min-width: 0;
    font-family: var(--font-mono);
    font-size: 0.85em;
    word-break: break-all;
    background: none;
    padding: 0;
  }
  .zg-copy {
    border: 1px solid var(--border);
    background: var(--bg);
    border-radius: var(--r-sm);
    padding: 0.35em 0.8em;
    font-size: 0.8em;
    cursor: pointer;
    color: var(--fg);
  }
  .zg-copy:hover { border-color: var(--accent); color: var(--accent); }
  .zg-copy.zg-copied { color: #056635; border-color: #056635; }

  .zg-permalink { font-family: var(--font-mono); font-size: 0.85em; word-break: break-all; }
</style>

<script type="module" src="/zerog-uploader-runtime.js"></script>
