---
import BaseLayout from "~/layouts/BaseLayout.astro";
import DemoNav from "~/components/DemoNav.astro";

// Recorded decision timeline — narrates the seven-step pipeline once.
// Each entry is one row in the live stream a real daemon would emit.
const timeline = [
  { ts: "+00.0s", actor: "agent",  evt: "POST /v1/payment-requests · APRP envelope (swap 0.05 ETH → USDC, sepolia)" },
  { ts: "+00.0s", actor: "sbo3l",  evt: "schema: deny_unknown_fields ✓ · all required fields present" },
  { ts: "+00.0s", actor: "sbo3l",  evt: "JCS-canonical request hash: 0xe044f13c5acb…" },
  { ts: "+00.0s", actor: "sbo3l",  evt: "nonce-replay gate: nonce 01HZRG… not seen ✓" },
  { ts: "+00.1s", actor: "policy", evt: "decision: allow · matched rules [risk.low, asset.weth, chain.sepolia]" },
  { ts: "+00.1s", actor: "policy", evt: "budget commit: 0.05 ETH (per-agent: 0.42/1.00 · per-vendor: 0.10/0.50 · global: 4.83/50.00)" },
  { ts: "+00.1s", actor: "audit",  evt: "append event · prev_event_hash 0x9aF3… · payload_hash 0x4c81…" },
  { ts: "+00.1s", actor: "audit",  evt: "Ed25519 signature: ed25519:…6f2c (chain length now 4220)" },
  { ts: "+00.2s", actor: "exec",   evt: "uniswap-sepolia adapter · quote 0xEd1f…2FB3 · sqrt_price_x96 863470429016…" },
  { ts: "+00.3s", actor: "exec",   evt: "execution_ref: 0xab12cd… (Sepolia tx hash)" },
  { ts: "+00.3s", actor: "sbo3l",  evt: "PolicyReceipt + executor_evidence emitted to agent" },
  { ts: "+00.4s", actor: "agent",  evt: "received signed receipt · request_hash 0xe044f1… · decision allow" },
];
---
<BaseLayout
  title="Demo · 2 — Watch a decision"
  description="Replay a recorded decision: APRP envelope → policy decision → budget commit → audit append → signed receipt."
>
  <section class="step">
    <DemoNav current={2} />
    <h1>Step 2 — Watch a decision</h1>
    <p class="lede">
      One real decision, replayed end-to-end. The actual pipeline takes ~80 ms; this page paces the events at human-readable speed so you can see each gate fire.
    </p>

    <ol class="timeline">
      {timeline.map((row) => (
        <li class={`actor-${row.actor}`}>
          <span class="ts">{row.ts}</span>
          <span class="actor">{row.actor}</span>
          <span class="evt">{row.evt}</span>
        </li>
      ))}
    </ol>

    <aside class="caption">
      <p>Every row corresponds to a real audit event. Replay them yourself with <code>bash demo-scripts/run-openagents-final.sh</code>. The full audit + capsule contract lives in <a href="https://sbo3l-docs.vercel.app/concepts/audit-log">/concepts/audit-log</a> and <a href="https://sbo3l-docs.vercel.app/concepts/capsule">/concepts/capsule</a>.</p>
    </aside>
  </section>
</BaseLayout>

<style>
  section.step { max-width: var(--max); margin: 2em auto 4em; padding: 0 1.5em; }
  section.step h1 { font-size: var(--fs-3); margin-bottom: 0.5em; }
  section.step .lede { color: var(--muted); margin-bottom: 1.5em; max-width: 700px; }

  .timeline { list-style: none; padding: 0; margin: 0 0 1.5em; border: 1px solid var(--border); border-radius: var(--r-md); overflow: hidden; }
  .timeline li {
    display: grid;
    grid-template-columns: 5em 5em 1fr;
    gap: 0.8em;
    padding: 0.55em 1em;
    border-top: 1px solid var(--border);
    font-size: 0.9em;
    font-family: var(--font-mono);
  }
  .timeline li:first-child { border-top: 0; }
  .timeline .ts { color: var(--muted); }
  .timeline .actor { color: var(--accent); text-transform: uppercase; font-size: 0.75em; align-self: center; }
  .timeline li.actor-policy .actor,
  .timeline li.actor-audit  .actor { color: var(--accent); }
  .timeline li.actor-agent  .actor { color: var(--muted); }
  .timeline .evt { color: var(--fg); word-break: break-word; }

  .caption { background: var(--code-bg); border: 1px solid var(--border); border-radius: var(--r-md); padding: 1em 1.2em; color: var(--muted); font-size: 0.92em; }
  .caption p { margin: 0; }

  @media (max-width: 640px) {
    .timeline li { grid-template-columns: 4em 4em 1fr; font-size: 0.78em; gap: 0.4em; padding: 0.5em 0.7em; }
  }
</style>
