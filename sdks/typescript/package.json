{
  "name": "@sbo3l/sdk",
  "version": "1.2.0",
  "description": "Official TypeScript SDK for SBO3L — the cryptographically verifiable trust layer for autonomous AI agents.",
  "license": "MIT",
  "author": "Daniel Babjak <babjak_daniel@hotmail.com>",
  "homepage": "https://sbo3l.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/B2JK-Industry/SBO3L-ethglobal-openagents-2026.git",
    "directory": "sdks/typescript"
  },
  "bugs": {
    "url": "https://github.com/B2JK-Industry/SBO3L-ethglobal-openagents-2026/issues"
  },
  "keywords": [
    "sbo3l",
    "agent",
    "policy",
    "audit",
    "ed25519",
    "passport",
    "trust",
    "ai-agent"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./passport": {
      "types": "./dist/passport.d.ts",
      "import": "./dist/passport.js",
      "require": "./dist/passport.cjs"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js",
      "require": "./dist/auth.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    },
    "./cross-agent": {
      "types": "./dist/cross-agent.d.ts",
      "import": "./dist/cross-agent.js",
      "require": "./dist/cross-agent.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "size": "npm run build && gzip -c dist/index.js | wc -c"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.4.0",
    "canonicalize": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
